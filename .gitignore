# Build artifacts
dist/
build/

# Zig build artifacts
.zig-cache/
zig-out/
# Local Zig dependency package cache (fetched on demand; see build.zig.zon)
zig-pkg/

# Dependencies
node_modules/
vendor/

# Python virtual environments
venv/
.venv/

# Python bytecode (the shell tests embed Python via pty; __pycache__ is generated)
__pycache__/
*.pyc

# Environment files
.env
.env.*

# OS-specific files
.DS_Store
Thumbs.db

# Editor / IDE
*.swp
*.swo
.idea/
.vscode/

# Local agent runtime artifacts (subagent transcripts, session meta, progress)
.pi-subagents/
.pi/

# Audit / scratch residue — never commit (see AGENTS.md). These are generated
# by test/audit harnesses and must never enter history.
.audit*/
calls.log
.last-output
tmp.*
scratch/
